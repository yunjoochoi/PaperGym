FROM python:3.11-slim
WORKDIR /papergym
COPY pyproject.toml ./
COPY src ./src
# Install the package itself without pulling data/network-heavy host deps such
# as datasets/litellm. Sandboxed code reaches LLMs only through gym_client.
RUN pip install --no-cache-dir --no-deps -e . \
    && pip install --no-cache-dir scikit-learn numpy
# datasets/labels are NOT baked in — labels live host-side only.
WORKDIR /work
